  <path d="M12 2C9.5 2 4 5.5 4 12c0 3.5 1.5 6.5 3.5 8.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>
  <path d="M12 22c2.5 0 8-3.5 8-10 0-3.5-1.5-6.5-3.5-8.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>
  <%# Inner dialogue bubble hint -%>
  <path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.6"/>
  <%# Central trust dot -%>
  <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
</svg>
