<%# Usage: include with { size: 24 } -%>
<svg width="<%= typeof size !== 'undefined' ? size : 24 %>" height="<%= typeof size !== 'undefined' ? size : 24 %>" viewBox="0 0 24 24" fill="none" class="civic-knot" aria-label="Civitas">
