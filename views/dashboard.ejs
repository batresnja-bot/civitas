<%- include('partials/nav') %>

<main class="container">
  <div class="content-header">
    <h1>Your Dashboard</h1>
    <p class="content-subtitle">Welcome back, <%= user.display_name || user.username %>.</p>
  </div>

  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-icon">📝</span>
      <span class="stat-number"><%= stats.totalPosts %></span>
      <span class="stat-label">Posts</span>
    </div>
    <div class="stat-card">
      <span class="stat-icon">✅</span>
      <span class="stat-number"><%= stats.approved %></span>
      <span class="stat-label">Approved</span>
    </div>
    <div class="stat-card">
      <span class="stat-icon">⏳</span>
      <span class="stat-number"><%= stats.pending %></span>
      <span class="stat-label">Pending</span>
    </div>
    <div class="stat-card">
      <span class="stat-icon">⭐</span>
      <span class="stat-number"><%= stats.reputation.toFixed(0) %></span>
      <span class="stat-label">Reputation</span>
    </div>
  </div>

  <div class="dashboard-grid">
    <div class="dashboard-main">
      <div class="card">
        <div class="card-header">
          <h2>Your Posts</h2>
        </div>
        <% if (posts.length === 0) { %>
          <div class="empty-state">
            <p>No posts yet. Share something with your community.</p>
          </div>
        <% } else { %>
          <div class="posts-list">
            <% posts.slice(0, 10).forEach(post => { %>
              <a href="/c/<%= post.community_slug %>/p/<%= post.id %>" class="post-card">
                <div class="post-card-header">
                  <span class="post-badge <%= post.status %>"><%= post.status %></span>
                  <span class="post-community"><%= post.community_name %></span>
                </div>
                <h3><%= post.title || 'Untitled' %></h3>
                <p class="post-excerpt"><%= post.content.substring(0, 120) %><%= post.content.length > 120 ? '...' : '' %></p>
                <span class="post-time"><%= new Date(post.created_at).toLocaleDateString() %></span>
              </a>
            <% }) %>
          </div>
        <% } %>
      </div>

      <% if (notifications.length > 0) { %>
        <div class="card" style="margin-top:16px;">
          <div class="card-header">
            <h2>Recent Notifications</h2>
            <a href="/notifications" class="btn btn-ghost btn-sm">View all</a>
          </div>
          <div class="notifications-list">
            <% notifications.slice(0, 5).forEach(n => { %>
              <div class="notification-card <%= n.is_read ? '' : 'unread' %>">
                <div class="notification-icon">
                  <% if (n.notification_type === 'comment') { %>💬
                  <% } else if (n.notification_type === 'reaction') { %>⭐
                  <% } else if (n.notification_type === 'moderation') { %>⚖
                  <% } else { %>🔔
                  <% } %>
                </div>
                <div class="notification-content">
                  <h3><%= n.title %></h3>
                  <p><%= n.message %></p>
                </div>
                <% if (n.link) { %>
                  <a href="<%= n.link %>" class="btn btn-outline btn-sm">View</a>
                <% } %>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>

    <div class="dashboard-sidebar">
      <div class="card">
        <div class="card-header">
          <h2>Your Trust Level</h2>
        </div>
        <div class="trust-explanation">
          <div class="trust-progress">
            <% for (let i = 0; i <= 5; i++) { %>
              <div class="trust-step <%= i <= stats.trustLevel.level ? 'active' : '' %>">
                <div class="trust-dot"></div>
              </div>
              <% if (i < 5) { %>
                <div class="trust-line"></div>
              <% } %>
            <% } %>
          </div>
          <div class="trust-labels">
            <span>Newcomer</span>
            <span>Elder</span>
          </div>
          <p class="trust-hint">Current level: <strong><%= stats.trustLevel.name %></strong> — <%= stats.trustLevel.description %></p>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2>Quick Actions</h2>
        </div>
        <div class="quick-actions">
          <a href="/c" class="btn btn-outline btn-full">Browse Communities</a>
          <a href="/c/new" class="btn btn-primary btn-full">Create Community</a>
          <a href="/moderation" class="btn btn-outline btn-full">Review Queue</a>
        </div>
      </div>
    </div>
  </div>
</main>
