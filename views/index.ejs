<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Civitas — Build communities people trust</title>
  <meta name="description" content="Civitas helps online communities create clear rules, review difficult cases, handle appeals, and share responsibility — without turning moderators into full-time police.">
  <link rel="stylesheet" href="/style.css">
</head>
<body class="landing-body">
  <%- include('partials/nav') %>
  <main>
    <!-- HERO -->
    <section class="hero-section">
      <div class="hero-glow"></div>
      <div class="container-narrow">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          Trust infrastructure for online communities
        </div>
        <h1 class="hero-title">Build communities <span class="hero-gradient">people trust</span>.</h1>
        <p class="hero-subtitle">Civitas helps communities create clear rules, make transparent decisions, resolve conflict, and share responsibility — without turning moderation into a full-time job.</p>
        <div class="hero-cta">
          <a href="/register" class="btn btn-primary btn-lg">Create your community</a>
          <a href="/c" class="btn btn-outline btn-lg">Explore the demo</a>
        </div>
        <p class="hero-trust-line">No black-box moderation. No social-credit scores. No invisible admin decisions.</p>
        <div class="hero-metrics">
          <div class="metric-item">
            <span class="metric-number">3</span>
            <span class="metric-label">Demo communities</span>
          </div>
          <div class="metric-divider"></div>
          <div class="metric-item">
            <span class="metric-number">50+</span>
            <span class="metric-label">Posts and discussions</span>
          </div>
          <div class="metric-divider"></div>
          <div class="metric-item">
            <span class="metric-number">100%</span>
            <span class="metric-label">Transparent decisions</span>
          </div>
        </div>
      </div>
    </section>

    <!-- PROBLEM -->
    <section class="problem-section">
      <div class="container-wide">
        <h2 class="section-title">The problem is not toxicity. It is broken trust.</h2>
        <div class="problem-grid">
          <div class="problem-card">
            <div class="problem-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <h3>Rules are unclear</h3>
            <p>Members do not know what is allowed. Moderators apply rules inconsistently. Trust erodes.</p>
          </div>
          <div class="problem-card">
            <div class="problem-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Moderators burn out</h3>
            <p>Every dispute lands on the same few people. Communities die when their founders get tired.</p>
          </div>
          <div class="problem-card">
            <div class="problem-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>
            </div>
            <h3>Appeals feel hopeless</h3>
            <p>Decisions are final. There is no path to challenge a ruling, even when it is clearly wrong.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="how-section">
      <div class="container-wide">
        <h2 class="section-title">How Civitas works</h2>
        <p class="section-subtitle">Five steps to a community that governs itself.</p>
        <div class="how-steps">
          <div class="how-step-card">
            <div class="how-step-num">1</div>
            <h4>Define your constitution</h4>
            <p>Write rules in plain language. Add examples. Define what matters.</p>
          </div>
          <div class="how-step-card">
            <div class="how-step-num">2</div>
            <h4>Launch your community</h4>
            <p>Invite members. Start posting. Everything works like a normal community.</p>
          </div>
          <div class="how-step-card">
            <div class="how-step-num">3</div>
            <h4>Screen intelligently</h4>
            <p>Content is checked against your rules. Clear content is approved automatically.</p>
          </div>
          <div class="how-step-card">
            <div class="how-step-num">4</div>
            <h4>Review together</h4>
            <p>Borderline cases go to community reviewers. Decisions include transparent rationale.</p>
          </div>
          <div class="how-step-card">
            <div class="how-step-num">5</div>
            <h4>Learn and evolve</h4>
            <p>Track appeals, refine rules, and grow your governance over time.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features-section">
      <div class="container-wide">
        <h2 class="section-title">Governance that does not kill participation</h2>
        <p class="section-subtitle">Civitas is a community platform first. Governance tools are there when you need them, invisible when you do not.</p>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <h3>Constitution builder</h3>
            <p>Turn community values into clear, enforceable rules with examples and appeal paths.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5V12"/><path d="M9.5 2A2.5 2.5 0 0 0 7 4.5V12"/><path d="M14 8h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2h2"/></svg>
            </div>
            <h3>Transparent review</h3>
            <p>Every moderation decision includes a reason, a rule citation, and a path to appeal.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3>Real appeals</h3>
            <p>If a decision is wrong, members can challenge it. Different reviewers re-examine the case.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <h3>Shared governance</h3>
            <p>Trusted members help review, propose changes, and shape the community together.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TRANSPARENCY -->
    <section class="transparency-section">
      <div class="container-wide">
        <h2 class="section-title">Transparent by design</h2>
        <div class="transparency-grid">
          <div class="transparency-item">
            <div class="transparency-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <h4>Rule versions</h4>
            <p>Every rule change is tracked. Members can see what changed and why.</p>
          </div>
          <div class="transparency-item">
            <div class="transparency-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <h4>Decision rationales</h4>
            <p>Every moderation decision explains which rule applied and how.</p>
          </div>
          <div class="transparency-item">
            <div class="transparency-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
            </div>
            <h4>Audit logs</h4>
            <p>All governance actions are logged. Nothing is invisible.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- BUILT FOR -->
    <section class="builtfor-section">
      <div class="container-wide">
        <h2 class="section-title">Built for real communities</h2>
        <div class="builtfor-grid">
          <div class="builtfor-card">
            <h4>Creator communities</h4>
            <p>Paid and free communities with clear norms and constructive feedback.</p>
          </div>
          <div class="builtfor-card">
            <h4>Course cohorts</h4>
            <p>Educational groups with respectful Q&A and mentor roles.</p>
          </div>
          <div class="builtfor-card">
            <h4>Open source projects</h4>
            <p>Code of conduct enforcement with maintainer transparency.</p>
          </div>
          <div class="builtfor-card">
            <h4>Professional guilds</h4>
            <p>Expertise-based communities with high-quality discussion standards.</p>
          </div>
          <div class="builtfor-card">
            <h4>Gaming communities</h4>
            <p>Voice and chat conduct with dispute resolution.</p>
          </div>
          <div class="builtfor-card">
            <h4>Civic groups</h4>
            <p>Structured deliberation with strong proposal processes.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- COMPARE -->
    <section class="compare-section">
      <div class="container-wide">
        <h2 class="section-title">Not a black-box AI judge</h2>
        <div class="compare-grid">
          <div class="compare-card old">
            <h3>Other platforms</h3>
            <ul>
              <li>AI decides — no explanation</li>
              <li>No appeal process</li>
              <li>Moderators are police, not guides</li>
              <li>Rules are vague and hidden</li>
              <li>Power is concentrated</li>
              <li>Decisions feel arbitrary</li>
            </ul>
          </div>
          <div class="compare-card new">
            <h3>Civitas</h3>
            <ul>
              <li>AI assists — humans decide</li>
              <li>Real appeals with different reviewers</li>
              <li>Moderators are supported, not overwhelmed</li>
              <li>Rules are visible and versioned</li>
              <li>Governance is shared</li>
              <li>Every decision has a rationale</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- COMMUNITIES PREVIEW -->
    <% if (typeof communities !== 'undefined' && communities.length > 0) { %>
      <section class="features-section">
        <div class="container-wide">
          <h2 class="section-title">Active communities</h2>
          <div class="communities-grid">
            <% communities.slice(0, 6).forEach(c => { %>
              <a href="/c/<%= c.slug %>" class="community-card">
                <h3><%= c.name %></h3>
                <p><%= c.description %></p>
                <div class="community-card-footer">
                  <span><%= c.member_count %> members</span>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      </section>
    <% } %>

    <!-- FINAL CTA -->
    <section class="cta-section">
      <div class="container-narrow">
        <h2>Start with a template. Launch in minutes. Improve as you grow.</h2>
        <p>Your community should not depend on one exhausted moderator.</p>
        <div class="hero-cta">
          <a href="/register" class="btn btn-primary btn-xl">Create your community</a>
          <a href="/c" class="btn btn-outline btn-xl">Explore the demo</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <p>Civitas &mdash; Trust infrastructure for online communities.</p>
      <div class="footer-links">
        <a href="/c">Discover</a>
        <a href="/c/new">Create</a>
        <a href="/login">Log in</a>
      </div>
    </div>
  </footer>
</body>
</html>
