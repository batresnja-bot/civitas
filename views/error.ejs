<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Error' %> - Civitas</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="error-page">
    <div class="error-icon">⚠</div>
    <h1><%= typeof title !== 'undefined' ? title : 'Something went wrong' %></h1>
    <p><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></p>
    <a href="/" class="btn btn-primary">Go Home</a>
  </div>
</body>
</html>
