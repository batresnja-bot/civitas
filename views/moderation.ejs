<%- include('partials/nav') %>

<main class="container">
  <div class="content-header">
    <h1>Review Center</h1>
    <p class="content-subtitle">Review posts that need human judgment. All decisions require a rationale and will be visible to the community.</p>
  </div>

  <div class="card" style="margin-bottom:var(--space-4); background:var(--amber-50); border:1px solid var(--amber-200);">
    <div style="padding:var(--space-3); font-size:13px; color:var(--amber-800);">
      <strong>Conflict of interest:</strong> If you are involved in a dispute with the post author, or if you have a personal relationship that could affect your impartiality, please skip this review and let another reviewer handle it.
    </div>
  </div>

  <div class="moderation-tabs">
    <a href="/moderation" class="mod-tab active">Pending Review (<%= queue.length %>)</a>
  </div>

  <% if (queue.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
          <path d="M24 6L8 13v11c0 11 7 18 16 20.5C33 42 40 35 40 24V13L24 6z" stroke="currentColor" stroke-width="2" fill="none" opacity="0.4"/>
          <path d="M17 24l5 5 9-9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
        </svg>
      </div>
      <h3>All clear!</h3>
      <p>No posts pending review. Check back later.</p>
    </div>
  <% } else { %>
    <div class="moderation-list">
      <% queue.forEach(post => { %>
        <div class="moderation-card">
          <div class="moderation-card-header">
            <div class="moderation-meta">
              <span class="post-author">Reviewer #<%= Math.abs(post.user_id * 7 + 13) % 1000 %></span>
              <span class="post-community"><%= post.community_name %></span>
              <span class="moderation-score">Flag score: <%= (post.ai_score * 100).toFixed(0) %>%</span>
            </div>
            <span class="moderation-status status-<%= post.status %>"><%= post.status %></span>
          </div>

          <div class="moderation-content">
            <h3><%= post.title || 'Untitled' %></h3>
            <p><%= post.content.substring(0, 300) %><%= post.content.length > 300 ? '...' : '' %></p>
          </div>

          <div class="moderation-actions">
            <a href="/c/<%= post.community_slug %>/p/<%= post.id %>" class="btn btn-outline btn-sm" style="margin-right:auto;">View Full Post</a>
            <form method="POST" action="/moderation/<%= post.id %>/decision" class="moderation-form" onsubmit="return confirm('Reviewer identities are hidden. Your decision will be made public with this rationale. Continue?')">
              <input type="hidden" name="decision" value="approved">
              <input type="text" name="rationale" placeholder="Why is this approved?" required class="moderation-rationale-input" style="width:200px;">
              <button type="submit" class="btn btn-success btn-sm">Approve</button>
            </form>
            <form method="POST" action="/moderation/<%= post.id %>/decision" class="moderation-form" onsubmit="return confirm('Reviewer identities are hidden. Your decision will be made public with this rationale. Continue?')">
              <input type="hidden" name="decision" value="rejected">
              <input type="text" name="rationale" placeholder="Which rule was violated?" required class="moderation-rationale-input" style="width:200px;">
              <button type="submit" class="btn btn-danger btn-sm">Reject</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <% if (typeof recentDecisions !== 'undefined' && recentDecisions.length > 0) { %>
    <div class="recent-decisions" style="margin-top:var(--space-6);">
      <h2 style="font-size:16px; margin-bottom:var(--space-3);">Recent Decisions</h2>
      <div class="moderation-list">
        <% recentDecisions.forEach(post => { %>
          <div class="moderation-card" style="opacity: 0.7;">
            <div class="moderation-card-header">
              <div class="moderation-meta">
                <span class="post-author">Reviewer</span>
                <span class="post-community"><%= post.community_name %></span>
              </div>
              <span class="post-badge <%= post.decision %>"><%= post.decision %></span>
            </div>
            <div class="moderation-content">
              <h3><%= post.title || 'Untitled' %></h3>
              <% if (post.rationale) { %>
                <p class="moderation-rationale"><em>"<%= post.rationale %>"</em></p>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>
</main>
