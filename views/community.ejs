<%- include('partials/nav') %>

<main class="container">
  <div class="content-header">
    <div class="community-header">
      <div>
        <h1><%= community.name %></h1>
        <p class="content-subtitle"><%= community.description %></p>
      </div>
      <div class="community-actions">
        <% if (currentUser && !isMember) { %>
          <form method="POST" action="/c/<%= community.slug %>/join">
            <button type="submit" class="btn btn-primary">Join</button>
          </form>
        <% } else if (currentUser && isMember && isMember.role !== 'owner') { %>
          <form method="POST" action="/c/<%= community.slug %>/leave">
            <button type="submit" class="btn btn-outline">Leave</button>
          </form>
        <% } %>
        <span class="member-count"><%= memberCount %> members</span>
      </div>
    </div>
  </div>

  <div class="community-nav">
    <a href="/c/<%= community.slug %>" class="community-nav-link active">Posts</a>
    <a href="/c/<%= community.slug %>/constitution" class="community-nav-link">Constitution</a>
    <a href="/c/<%= community.slug %>/proposals" class="community-nav-link">Proposals</a>
    <a href="/c/<%= community.slug %>/health" class="community-nav-link">Health</a>
    <% if (currentUser) { %>
      <a href="/c/<%= community.slug %>/new" class="btn btn-primary btn-sm">New Post</a>
    <% } %>
  </div>

  <% if (topTags.length > 0) { %>
    <div class="community-tags">
      <% topTags.forEach(tag => { %>
        <span class="tag"><%= tag.name %> (<%= tag.post_count || 0 %>)</span>
      <% }) %>
    </div>
  <% } %>

  <div class="posts-list">
    <% if (posts.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">📝</div>
        <h3>No posts yet</h3>
        <p>Be the first to share something.</p>
        <% if (currentUser) { %>
          <a href="/c/<%= community.slug %>/new" class="btn btn-primary">Create Post</a>
        <% } %>
      </div>
    <% } else { %>
      <% posts.forEach(post => { %>
        <a href="/c/<%= community.slug %>/p/<%= post.id %>" class="post-card">
          <div class="post-card-header">
            <span class="post-type-badge"><%= post.post_type %></span>
            <span class="post-author"><%= post.display_name || post.username %></span>
          </div>
          <h3><%= post.title %></h3>
          <p class="post-excerpt"><%= post.content.substring(0, 200) %><%= post.content.length > 200 ? '...' : '' %></p>
          <div class="post-card-footer">
            <span class="post-time"><%= new Date(post.created_at).toLocaleDateString() %></span>
          </div>
        </a>
      <% }) %>
    <% } %>
  </div>
</main>
